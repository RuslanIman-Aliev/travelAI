// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// For Authentication (NextAuth.js)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  trips         Trip[]
  liveGuides    LiveGuide[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Regular application models
model Trip {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  destination String   
  country     String?  
  startDate   DateTime
  endDate     DateTime
  daysCount   Int      
  imageUrl    String?
  
  budget      String?  
  interests   String[] 
  
  status      String   @default("draft") 
  aiGenerated Boolean  @default(false)
  isPublic    Boolean  @default(false)
  
  tripDays    Day[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Day {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  dayNumber Int      
  date      DateTime?
  summary   String?  
  
  activities Activity[]
}

model Activity {
  id                String  @id @default(cuid())
  dayId             String
  day               Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  
  title             String  
  description       String? 
  time              String? 
  
  // Data for places API integration
  placeName         String? 
  placeType         String? 
  googleSearchQuery String? 
  googlePlaceId     String? 
  
  latitude          Float?
  longitude         Float?
  photoUrl          String?
  
  estimatedCost     String? 
  
  order             Int     
}

model LiveGuide {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  startAddress  String?   
  startLat      Float     
  startLng      Float     
  
  radiusMeters  Int       
  
  places        LiveGuidePlace[]
  mapLink     String? 
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LiveGuidePlace {
  id            String    @id @default(cuid())
  liveGuideId   String
  liveGuide     LiveGuide @relation(fields: [liveGuideId], references: [id], onDelete: Cascade)

  googlePlaceId String    
  name          String
  address       String?
  category      String?   
  
  rating        Float?
  userRatingCount Int?

  lat           Float
  lng           Float
  distance      Float?   

  orderIndex    Int       
}